{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "core-tasks-route": {
        "ClusterId": "core-cluster",
        "Match": {
          "Path": "/api/tasks/{**catch-all}"
        }
      },
      "core-analytics-route": {
        "ClusterId": "core-cluster",
        "Match": {
          "Path": "/api/analytics/{**catch-all}"
        }
      },
      "core-signalr-route": {
        "ClusterId": "core-cluster",
        "Match": {
          "Path": "/task-hub/{**catch-all}"
        }
      },
      "collector-hangfire-route": {
        "ClusterId": "collector-cluster",
        "Match": {
          "Path": "/hangfire/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:7135"
          }
        }
      },
      "core-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:7164"
          }
        }
      },
      "collector-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:7112"
          }
        }
      }
    }
  }
}